{
  "manifest_version": 3,
  "name": "Alcance Legal Penal · Conexión MEV",
  "version": "1.1.0",
  "description": "Componente MEV de Alcance Legal Penal. Analiza expedientes del MEV (SCBA) con inteligencia jurídica penal — CPP PBA.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://mev.scba.gov.ar/*",
    "https://alcance-legal-penal.vercel.app/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Alcance Legal Penal · Conexión MEV"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://mev.scba.gov.ar/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://alcance-legal-penal.vercel.app/*",
        "http://localhost:5173/*"
      ],
      "js": ["detector.js"],
      "run_at": "document_start"
    }
  ]
}
