{
  "manifest_version": 3,
  "name": "Alcance Legal Penal — MEV Navigator",
  "version": "1.0.0",
  "description": "Análisis de expedientes judiciales del MEV con IA para defensa penal en la Provincia de Buenos Aires.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://mev.scba.gov.ar/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "MEV Navigator — Alcance Legal Penal"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://mev.scba.gov.ar/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
